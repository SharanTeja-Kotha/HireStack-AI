                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT DISTINCT
    -- ADD THIS LINE (you forgot it!)
    CONVERT(INT, FORMAT(CAST(job_posted_date AS DATE), 'yyyyMMdd')) AS date_id,
    
    CAST(job_posted_date AS DATE) AS full_date,
    YEAR(job_posted_date) AS year,
    MONTH(job_posted_date) AS month,
    LEFT(DATENAME(MONTH, job_posted_date), 20) AS month_name,
    DATEPART(QUARTER, job_posted_date) AS quarter,
    LEFT(DATENAME(WEEKDAY, job_posted_date), 20) AS day_of_week
FROM [dbo].[stg_jobmatch_raw]
WHERE job_posted_date IS NOT NULL
  AND ISDATE(job_posted_date) = 1</property>
