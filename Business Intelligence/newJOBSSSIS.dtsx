                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT DISTINCT
    r.job_title_short,
    TRIM(REPLACE(REPLACE(value, '[', ''), ']', '')) AS skill_name
FROM [dbo].[stg_jobmatch_raw] r
CROSS APPLY STRING_SPLIT(
    REPLACE(REPLACE(REPLACE(r.job_skills, '''', ''), '[', ''), ']', ''),
    ','
)
WHERE r.job_skills IS NOT NULL
  AND LEN(TRIM(r.job_skills)) &gt; 2
  AND r.job_skills &lt;&gt; 'None'
  AND TRIM(REPLACE(REPLACE(value, '[', ''), ']', '')) &lt;&gt; ''</property>
