    ISNULL(TRY_CAST(NULLIF(salary_hour_avg, 'None') AS DECIMAL(18,2)), 0.00) AS salary_hour_avg
    
FROM [dbo].[stg_jobmatch_raw]
WHERE job_title_short IS NOT NULL</property>
