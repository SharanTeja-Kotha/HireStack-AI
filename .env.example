# ─────────────────────────────────────────────────────────────────────────────
# HireStack — environment template. Copy to `.env` and fill in real values.
#   cp .env.example .env
# `.env` is gitignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Azure SQL — "Jobs_DW" data warehouse (job offers source)
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DB=Jobs_DW
AZURE_SQL_USER=your_sql_user
AZURE_SQL_PASSWORD=__set_me__
AZURE_SQL_PORT=1433

# Rows imported from Azure when the jobs table is empty at startup (0 = all)
AZURE_SQL_IMPORT_LIMIT=5000

# App JWT secret (used by the backend)
# JWT_SECRET=change-me-in-production
